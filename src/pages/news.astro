---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.vue";
import Footer from "../components/Footer.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((b, a) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const postsPerPage = 10;
const totalPages = Math.ceil(posts.length / postsPerPage);
const currentPagePosts = posts.slice(0, postsPerPage);
---

<Layout title="News - Logic Moon">
  <Navigation client:visible />
  <main class="min-h-screen bg-primary-600">
    <section class="py-24 bg-primary-600 text-secondary-200">
      <div class="w-[min(1200px,90vw)] mx-auto">
        <div class="mb-8">
          <div class="font-mono text-xs tracking-[0.25em] uppercase text-accent-500">Latest News</div>
          <h2 class="mt-2 text-[clamp(22px,3.2vw,30px)] font-bold leading-tight">New releases, updates and features.</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            currentPagePosts.map((post) => (
              <article class="bg-primary-500 border border-primary-500 rounded-[10px] p-5 text-secondary-200 flex flex-col">
                {post.data.image && (
                  <div class="h-64 bg-primary-900 rounded-md mb-4 overflow-hidden">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                    />
                  </div>
                )}
                <div class="flex flex-col h-full">
                  <div class="flex justify-between items-start mb-3 gap-3">
                    <h3 class="font-semibold mb-1 text-secondary-200 leading-tight">
                      <a href={`/news/${post.slug}`} class="hover:text-accent-500 transition-colors duration-200">
                        {post.data.title}
                      </a>
                    </h3>
                    <time class="font-mono text-xs tracking-[0.2em] uppercase text-secondary-500 whitespace-nowrap">
                      {post.data.pubDate.toLocaleDateString("en-EN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                  </div>
                  <p class="text-secondary-500 leading-relaxed mb-6 min-h-[72px] max-h-[72px] overflow-hidden">
                    {post.data.description}
                  </p>
                  <a href={`/news/${post.slug}`} class="mt-auto text-accent-700 hover:text-accent-600 transition-colors duration-200 inline-block hover:no-underline font-mono uppercase tracking-[0.25em] text-xs">
                    read the post
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        {
          totalPages > 1 && (
            <nav class="flex items-center justify-center gap-4 mt-16" aria-label="Pagination">
              <div class="flex gap-2">
                {Array.from({ length: totalPages }, (_, i) => i + 1).map(
                  (num) => (
                    <a
                      href={num === 1 ? "/news" : `/news/page/${num}`}
                      class={`w-10 h-10 flex items-center justify-center transition-colors duration-200 ${
                        num === 1
                          ? "bg-accent-500 text-primary-900"
                          : "bg-secondary-150 text-accent-700 hover:bg-accent-50"
                      }`}
                      aria-label={`Go to page ${num}`}
                      aria-current={num === 1 ? "page" : undefined}>
                      {num}
                    </a>
                  )
                )}
              </div>

              {totalPages > 1 && (
                <a
                  href="/news/page/2"
                  class="bg-accent-500 hover:bg-accent-600 text-primary-900 px-6 py-2 transition-colors duration-200 font-mono uppercase tracking-[0.2em]"
                  aria-label="Go to next page">
                  Nächste →
                </a>
              )}
            </nav>
          )
        }

        <p class="text-center text-secondary-500 mt-8 font-mono uppercase tracking-[0.2em] text-xs">
          Page 1 from {totalPages}
          (1-{Math.min(postsPerPage, posts.length)} of {posts.length})
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
