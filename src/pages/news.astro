---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.vue";
import Footer from "../components/Footer.astro";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((b, a) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());

const postsPerPage = 10;
const totalPages = Math.ceil(posts.length / postsPerPage);
const currentPagePosts = posts.slice(0, postsPerPage);
---

<Layout title="News - Logic Moon">
  <Navigation client:visible />
  <main class="min-h-screen bg-primary">
    <section class="section dark">
      <div class="container">
        <div class="section-header">
          <div class="eyebrow">Latest News</div>
          <h2 class="text-secondary-200 font-bold leading-tight">New releases, updates and features.</h2>
        </div>

        <div class="news-grid">
          {
            currentPagePosts.map((post) => (
              <article class="card">
                {post.data.image && (
                  <div class="card-media">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                    />
                  </div>
                )}
                <div class="card-body">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="card-title text-secondary-200 leading-tight">
                      <a href={`/news/${post.slug}`} class="hover:text-primary-400 transition-colors duration-200">
                        {post.data.title}
                      </a>
                    </h3>
                    <time class="card-meta whitespace-nowrap ml-4">
                      {post.data.pubDate.toLocaleDateString("en-EN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                  </div>
                  <p class="text-secondary-500 leading-relaxed mb-6 clamp-3">
                    {post.data.description}
                  </p>
                  <a href={`/news/${post.slug}`} class="card-link text-accent-700 hover:text-accent-600 transition-colors duration-200 inline-block hover:no-underline mono uppercase tracking-[0.25em] text-xs">
                    read the post
                  </a>
                </div>
              </article>
            ))
          }
        </div>

        {
          totalPages > 1 && (
            <nav class="flex items-center justify-center gap-4 mt-16" aria-label="Pagination">
              <div class="flex gap-2">
                {Array.from({ length: totalPages }, (_, i) => i + 1).map(
                  (num) => (
                    <a
                      href={num === 1 ? "/news" : `/news/page/${num}`}
                      class={`w-10 h-10 flex items-center justify-center transition-colors duration-200 ${
                        num === 1
                          ? "bg-accent-500 text-primary-900"
                          : "bg-secondary-150 text-accent-700 hover:bg-accent-50"
                      }`}
                      aria-label={`Go to page ${num}`}
                      aria-current={num === 1 ? "page" : undefined}>
                      {num}
                    </a>
                  )
                )}
              </div>

              {totalPages > 1 && (
                <a
                  href="/news/page/2"
                  class="bg-accent-500 hover:bg-accent-600 text-primary-900 px-6 py-2 transition-colors duration-200 mono uppercase tracking-[0.2em]"
                  aria-label="Go to next page">
                  Nächste →
                </a>
              )}
            </nav>
          )
        }

        <p class="text-center text-grey-600 mt-8 mono uppercase tracking-[0.2em] text-xs">
          Page 1 from {totalPages}
          (1-{Math.min(postsPerPage, posts.length)} of {posts.length})
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .main-section {
    min-height: calc(100vh - 80px);
  }
</style>
