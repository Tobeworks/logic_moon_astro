---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.vue";
---

<Layout title="Logic Moon - Shop">
  <Navigation client:visible />

  <main class="bg-surface text-on-surface min-h-screen">
    <section class="max-w-4xl mx-auto px-6 py-20">
      <div class="text-center mb-16">
        <div class="w-1 h-20 bg-primary mx-auto mb-8"></div>
        <h1 class="text-6xl md:text-8xl font-light tracking-wider mb-6 text-on-surface">
          SHOP
        </h1>
        <p class="text-xl font-light text-on-surface/60 tracking-wide">
          Support Logic Moon
        </p>
        <div class="w-32 h-px bg-on-surface/20 mx-auto mt-8"></div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-on-surface/10 mb-16">
        <div class="bg-surface p-8">
          <p class="text-xs uppercase tracking-widest text-on-surface/40 mb-3">Sounds</p>
          <p class="text-on-surface/80 font-light leading-relaxed text-sm">
            Handcrafted raw guitar drones and textures — designed for ambient and cinematic productions.
          </p>
        </div>
        <div class="bg-surface p-8">
          <p class="text-xs uppercase tracking-widest text-on-surface/40 mb-3">Posters</p>
          <p class="text-on-surface/80 font-light leading-relaxed text-sm">
            Ultra high resolution print sets in uncompressed TIFF format. Art from the Logic Moon universe, ready to print.
          </p>
        </div>
        <div class="bg-surface p-8">
          <p class="text-xs uppercase tracking-widest text-on-surface/40 mb-3">Wallpapers</p>
          <p class="text-on-surface/80 font-light leading-relaxed text-sm">
            High resolution wallpapers up to 10,000px — direct from the cover art of Logic Moon releases.
          </p>
        </div>
      </div>

      <div class="text-center">
        <a
          href="https://ko-fi.com/logicmoonmusic/shop"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block px-12 py-4 border border-on-surface/30 text-on-surface uppercase tracking-widest text-sm font-light hover:border-primary hover:text-primary transition-colors duration-300">
          Browse Shop
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
