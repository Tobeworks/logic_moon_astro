---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import Navigation from "../components/Navigation.vue";
import { Picture } from "astro:assets";
import portrait from "../assets/img/Logic Woods 3.webp";
import releases from '../releases.js';
---

<Layout title="Logic Moon Biography">
  <Navigation client:visible />

  <main class="bg-surface text-on-surface">
    <!-- Hero Section -->
    <section class="py-32 px-8 md:px-16 bg-surface-container-low">
      <div class="max-w-5xl mx-auto text-center">
        <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
          BIOGRAPHY
        </span>
        <h1 class="text-[clamp(48px,7vw,72px)] font-black tracking-tighter mb-4 text-on-surface uppercase">
          LOGIC MOON
        </h1>
        <p class="text-on-surface-variant font-mono uppercase tracking-[0.25em] text-[10px]">
          TOBIAS LORSBACH
        </p>
      </div>
    </section>

    <!-- About Section with Portrait -->
    <section class="py-32 px-8 md:px-16 bg-surface">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
          <!-- Text Content -->
          <div>
            <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
              THE ARCHITECT
            </span>
            <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-8">
              TOBIAS LORSBACH
            </h2>
            <div class="text-on-surface-variant font-light leading-relaxed space-y-6">
              <p>
                Tobias Lorsbach is a Mainz, Germany-based artist known as <span class="font-medium text-on-surface">Logic Moon</span> and <span class="font-medium text-on-surface">Aethery Fields</span>. His previous releases have appeared on internationally recognized labels such as Whitelabrecs, Archives, Archipel, DRONARIVM, Ambientologist, Shimmering Moods, and his own <span class="font-medium text-on-surface">The Moon Records</span> imprint across both physical and digital formats.
              </p>
              <p>
                He spent many years in the minimal techno scenes since the early 2000s, and whilst out on a field recording excursion, he fell upon the idea of layering some ambient drones. From here, his debut album as Logic Moon was born - "Herbst11".
              </p>
              <p>
                Tobias' musical background has drawn in a widescreen of genres, with him having performed guitar in a death metal band, embarked on a DJ career, and now established himself as an ambient musician. His varied experiences have only served to give birth to a range of ideas which are evident in his acclaimed albums.
              </p>
              <div class="bg-surface-container border border-outline-variant/10 p-8 my-8">
                Logic Moon has become well known for his mastering and post-production work for internationally recognized labels like Whitelabrecs, DRONARIVM, Archives, and many artists all over the globe.
              </div>
              <p>
                Recent collaborative projects include works with Swedish cellist Henrik Meierkord on albums such as "Inseln" (2022) and "Ewiger Wald" (2024), as well as partnerships with artists like Sven Laux and Scarless Arms.
              </p>
            </div>
          </div>

          <!-- Portrait -->
          <div class="flex justify-center md:justify-end">
            <div class="w-full max-w-md bg-surface-container-lowest">
              <Picture
                src={portrait}
                alt="Tobias Lorsbach portrait"
                widths={[400, 800, 1200]}
                sizes="(min-width: 768px) 50vw, 100vw"
                formats={["avif", "webp"]}
                class="w-full grayscale-[50%] hover:grayscale-0 transition-all duration-700 aspect-[4/5] object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Musical Style Section -->
    <section class="py-32 px-8 md:px-16 bg-surface-container-low">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
            MUSICAL STYLE
          </span>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
            SOUND AND AESTHETICS
          </h2>
        </div>
        <div class="text-on-surface-variant font-light leading-relaxed space-y-6">
          <p>
            Logic Moon's music merges <span class="font-medium text-on-surface">ambient, drone and neoclassical</span> influences. Typical are <span class="font-medium text-on-surface">sound-painterly, cinematic soundscapes</span> with electronic and acoustic elements.
          </p>
          <p>
            His pieces often begin with guitar or piano motifs, overlaid with flowing synthesizer drones, strings and field recordings. An example of this is the album The Unavoidable Death of Loneliness: It weaves "melodic piano and guitar lines" with dark string sounds and hammering rhythms.
          </p>
          <div class="bg-surface-container border border-outline-variant/10 p-8 my-8">
            Neoclassical components also appear – for example, the collaboration album The Quiet Companion (2023) is characterized by "gentle neoclassical pieces with piano, synthesizer pads and strings".
          </div>
          <p>
            His Lux EP (2023), for example, is described as an "atmospheric sound tapestry" that combines contemporary ambient electronics with subtle neoclassical touches. Critics consistently praise the <span class="font-medium text-on-surface">dense atmosphere</span> and the mixture of organic and synthetic sounds.
          </p>
        </div>
      </div>
    </section>

    <!-- Collaborations Section -->
    <section class="py-32 px-8 md:px-16 bg-surface">
      <div class="max-w-5xl mx-auto">
        <div class="mb-16">
          <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
            COLLABORATIONS
          </span>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
            ARTISTS AND LABELS
          </h2>
        </div>
        <div class="text-on-surface-variant font-light leading-relaxed">
          <p class="mb-12">
            Logic Moon frequently works with other artists and labels. Significant collaborations include:
          </p>

          <div class="space-y-12">
            <div class="border-l border-outline-variant/20 pl-8">
              <h3 class="font-bold text-on-surface mb-3 text-lg">SVEN LAUX</h3>
              <p class="text-sm leading-relaxed">
                Several albums were released together: The Unavoidable Death of Loneliness (2022, Ambientologist) and The Quiet Companion (2023, Shimmering Moods). Both albums show the close musical partnership of the two composers.
              </p>
            </div>

            <div class="border-l border-outline-variant/20 pl-8">
              <h3 class="font-bold text-on-surface mb-3 text-lg">HENRIK MEIERKORD</h3>
              <p class="text-sm leading-relaxed">
                The Swedish cellist appeared on the mini albums Ewiger Wald and Ewiger Wald Addendum (2024). Logic Moon mixes his electronic drones with Meierkord's cello into neoclassical ambient studies here.
              </p>
            </div>

            <div class="border-l border-outline-variant/20 pl-8">
              <h3 class="font-bold text-on-surface mb-3 text-lg">SCARLESS ARMS</h3>
              <p class="text-sm leading-relaxed">
                With this producer, Logic Moon shared the Moon Scars EP in 2023, a six-track collaboration in cinematic ambient style.
              </p>
            </div>

            <div class="border-l border-outline-variant/20 pl-8">
              <h3 class="font-bold text-on-surface mb-3 text-lg">LABELS</h3>
              <p class="text-sm leading-relaxed">
                In addition to the already mentioned labels Ambientologist and Shimmering Moods, he released on Archipel (D DR), Archives (GB), DE_ST_REC, Dronarivm (D), Whitelabrecs (JP) and his own label Logic Moon Records or spontanMusik.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Discography Section -->
    <section class="py-32 px-8 md:px-16 bg-surface-container-low">
      <div class="max-w-6xl mx-auto">
        <div class="mb-16">
          <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
            DISCOGRAPHY
          </span>
          <h2 class="text-4xl md:text-5xl font-bold tracking-tight">
            RELEASES AND SINGLES
          </h2>
        </div>
        <p class="text-on-surface-variant font-light leading-relaxed mb-12">
          Logic Moon has released numerous albums, EPs and singles since 2012.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4" role="list">
          {[...releases].sort((a, b) => parseInt(a.year) - parseInt(b.year) || a.id - b.id).map((release, index) => {
            const link = release.bandcamp || release.spotify || release.apple || release.amazon;
            const coverPath = `/images/covers/${release.cover}`;

            return (
              <div 
                class="flex items-center gap-4 py-3 px-4 rounded-none hover:bg-surface-container transition-colors" 
                role="listitem"
                data-aos="fade-up"
                data-aos-delay={index * 10}
              >
                <div class="w-14 h-14 flex-shrink-0 bg-surface-container-lowest overflow-hidden">
                  {link ? (
                    <a href={link} target="_blank" rel="noopener noreferrer" class="block">
                      <img 
                        src={coverPath} 
                        alt={`Cover for ${release.title}`} 
                        class="w-full h-full object-cover grayscale-[50%] hover:grayscale-0 transition-all duration-700" 
                      />
                    </a>
                  ) : (
                    <img 
                      src={coverPath} 
                      alt={`Cover for ${release.title}`} 
                      class="w-full h-full object-cover grayscale-[50%]" 
                    />
                  )}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="text-[10px] uppercase tracking-[0.2em] text-on-surface/40 mb-1">{release.year}</div>
                  {link ? (
                    <a href={link} target="_blank" rel="noopener noreferrer" class="font-bold text-on-surface hover:text-primary transition-colors no-underline line-clamp-2">
                      {release.title}
                    </a>
                  ) : (
                    <span class="font-bold text-on-surface line-clamp-2">{release.title}</span>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
