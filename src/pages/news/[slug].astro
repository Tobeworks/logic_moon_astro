---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.vue";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = {
  post: CollectionEntry<"blog">;
};

const { post } = Astro.props;
const { Content } = await post.render();
---

<Layout
  title={`${post.data.title} - Logic Moon`}
  description={post.data.description}
  image={post.data.image}
  type="article"
  pubDate={post.data.pubDate}>
  <Navigation client:visible />
  <main class="min-h-screen bg-surface text-on-surface">
    <section class="py-20 px-8 md:px-16">
      <div class="max-w-3xl mx-auto">
        <!-- Back Link -->
        <a href="/news" class="inline-flex items-center gap-2 text-primary text-xs uppercase tracking-widest hover:gap-4 transition-all mb-12 no-underline">
          <span>←</span> BACK TO NEWS
        </a>

        <article class="bg-surface-container border border-outline-variant/10">
          <header class="text-center md:p-12">
            {
              post.data.image && (
                <div class="mb-8">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full max-w-2xl mx-auto grayscale-[40%] brightness-90"
                  />
                </div>
              )
            }
            <h1 class="text-3xl md:text-4xl font-bold mb-6 text-on-surface tracking-tight">
              {post.data.title}
            </h1>
            <div
              class="flex justify-center items-center gap-4 text-on-surface/40 font-mono uppercase tracking-[0.2em] text-[10px] mb-6">
              <time datetime={post.data.pubDate.toISOString()}>
                {
                  post.data.pubDate.toLocaleDateString("en-EN", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                }
              </time>
              <span>•</span>
              <span>TOBIAS LORSBACH</span>
            </div>
            <p class="text-lg text-on-surface-variant italic max-w-2xl px-3 mx-auto font-light">
              {post.data.description}
            </p>
          </header>

          <div class="prose prose-lg max-w-none px-6 md:px-12 pb-12">
            <Content />
          </div>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .prose :global(h2) {
    font-size: 1.75rem;
    font-weight: 700;
    color: #eae0d5;
    margin-top: 2.5rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .prose :global(h3) {
    font-size: 1.375rem;
    font-weight: 600;
    color: #e6e1df;
    margin-top: 1.75rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .prose :global(h4) {
    font-size: 1.125rem;
    font-weight: 600;
    color: #d1c4b9;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .prose :global(p) {
    color: #d1c4b9;
    line-height: 1.75;
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .prose :global(a) {
    color: #e3c7a9;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
  }

  .prose :global(a:hover) {
    color: #fbdebf;
  }

  .prose :global(img) {
    border-radius: 0;
    margin: 2rem auto;
    max-width: 100%;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #e3c7a9;
    padding-left: 1.5rem;
    padding-top: 0.75rem;
    padding-bottom: 0.75rem;
    background-color: #211f1e;
    margin: 2rem 0;
    font-style: italic;
    color: #e6e1df;
  }

  .prose :global(blockquote p) {
    color: #e6e1df;
  }

  .prose :global(code) {
    background-color: #0f0e0d;
    color: #e3c7a9;
    padding: 0.25rem 0.5rem;
    font-size: 0.875rem;
    font-family: 'Geist Mono Variable', monospace;
    border: 1px solid #4d453d;
  }

  .prose :global(pre) {
    background-color: #0f0e0d;
    color: #e6e1df;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 2rem 0;
    border: 1px solid #4d453d;
  }

  .prose :global(pre code) {
    color: #e6e1df;
    padding: 0;
    background: none;
    border: none;
  }

  .prose :global(ul),
  .prose :global(ol) {
    color: #d1c4b9;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .prose :global(ul li),
  .prose :global(ol li) {
    margin-bottom: 0.75rem;
    color: #d1c4b9;
  }

  .prose :global(strong) {
    color: #eae0d5;
    font-weight: 600;
  }

  .prose :global(em) {
    color: #d1c4b9;
    font-style: italic;
  }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid #4d453d;
    margin: 3rem 0;
  }
</style>
