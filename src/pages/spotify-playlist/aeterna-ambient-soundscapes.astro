---
import Navigation from "../../components/Navigation.vue";
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import { Image } from "astro:assets";
import aeterna from "../../assets/img/playlists/aeterna_cover2.jpg";
---

<Layout title="AETERNA - Ambient Soundscapes | Logic Moon">
  <Navigation client:visible />
  
  <main class="min-h-screen bg-surface text-on-surface">
    <!-- Hero Section -->
    <section class="py-32 px-8 md:px-16 bg-surface-container-low">
      <div class="max-w-6xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <!-- Cover Image -->
          <div class="flex justify-center md:justify-start" data-aos="fade-right">
            <div class="w-full max-w-md aspect-square bg-surface-container-lowest overflow-hidden">
              <Image
                src={aeterna}
                alt="AETERNA - Ambient Soundscapes"
                class="w-full h-full object-cover grayscale-[50%] hover:grayscale-0 transition-all duration-700"
                width="500"
                height="500"
              />
            </div>
          </div>
          
          <!-- Content -->
          <div class="flex flex-col justify-center" data-aos="fade-left">
            <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
              SPOTIFY PLAYLIST
            </span>
            <h1 class="text-4xl md:text-6xl font-black tracking-tighter mb-4 text-on-surface uppercase">
              AETERNA
            </h1>
            <p class="text-on-surface-variant font-light leading-relaxed mb-8">
              From timeless classic ambient compositions to cutting-edge neoclassical soundscapes and haunting ethereal drones, this handselected playlist offers a diverse array of atmospheric audio experiences.
            </p>
            
            <!-- Key Features -->
            <div class="space-y-4 mb-8">
              <div class="flex items-start gap-3">
                <span class="text-primary text-lg">•</span>
                <span class="text-on-surface-variant font-light text-sm">Expertly curated selection of top tier ambient tracks</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-primary text-lg">•</span>
                <span class="text-on-surface-variant font-light text-sm">Spans classic ambient, neoclassical, and ethereal drone genres</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-primary text-lg">•</span>
                <span class="text-on-surface-variant font-light text-sm">Dynamic intensity progression for an engaging listening experience</span>
              </div>
              <div class="flex items-start gap-3">
                <span class="text-primary text-lg">•</span>
                <span class="text-on-surface-variant font-light text-sm">Perfect for relaxation, meditation, focus, and creative inspiration</span>
              </div>
            </div>
            
            <!-- CTA Button -->
            <a 
              href="https://open.spotify.com/playlist/5nLtdBW5YkoA233n6t0hF6" 
              target="_blank"
              rel="noopener noreferrer"
              class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-8 py-4 text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all no-underline inline-block text-center max-w-xs"
            >
              Listen on Spotify
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Spotify Player Section -->
    <section class="py-32 px-8 md:px-16 bg-surface">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-12" data-aos="fade-up">
          <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
            NOW PLAYING
          </span>
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight">
            FULL PLAYLIST
          </h2>
        </div>
        
        <div class="bg-surface-container-lowest border border-outline-variant/10 overflow-hidden" data-aos="fade-up">
          <iframe
            src="https://open.spotify.com/embed/playlist/5nLtdBW5YkoA233n6t0hF6?utm_source=generator&theme=0"
            width="100%"
            height="600"
            allowfullscreen=""
            allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
            loading="lazy"
            class="border-0"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Description Section -->
    <section class="py-32 px-8 md:px-16 bg-surface-container-low">
      <div class="max-w-4xl mx-auto text-center" data-aos="fade-up">
        <p class="text-on-surface-variant font-light leading-relaxed text-lg">
          Let the captivating sounds of AETERNA transport you to otherworldly landscapes and serene mental states. Embark on an ambient adventure that will soothe your mind, inspire your creativity, and elevate your mood.
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
