---
import pack from "../../package.json";
---

<!-- Footer -->
<footer
  class="bg-surface-container-lowest border-t border-outline-variant/20"
  id="footer">
  <div class="container mx-auto px-8 md:px-16 py-12">
    <div class="flex flex-col md:flex-row justify-between items-center gap-8">
      <!-- Logo -->
      <div class="text-sm font-bold text-on-surface">LOGIC MOON</div>

      <!-- Social Links -->
      <div class="flex flex-wrap justify-center gap-8">
        <a
          href="https://www.youtube.com/@LogicMoonMusic"
          target="_blank"
          class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300"
          aria-label="YouTube">
          Youtube
        </a>
        <a
          href="https://soundcloud.com/logic-moon"
          target="_blank"
          class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300"
          aria-label="SoundCloud">
          Soundcloud
        </a>
        <a
          href="https://www.facebook.com/logicmoonmusic/"
          target="_blank"
          class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300"
          aria-label="Facebook">
          Facebook
        </a>
        <a
          href="https://open.spotify.com/artist/3cqJW0hZR5efv5YWJKVMw8?si=C5rFleDOTPmw6Dww9ffq_g"
          target="_blank"
          class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300"
          aria-label="Spotify">
          Spotify
        </a>
        <a
          href="https://logicmoon.bandcamp.com/"
          target="_blank"
          class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300"
          aria-label="Bandcamp">
          Bandcamp
        </a>
        <a
          href="https://www.instagram.com/logicmoonmusic/"
          target="_blank"
          class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300"
          aria-label="Instagram">
          Instamoon
        </a>
      </div>

      <!-- Credits -->
      <div class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40">
        © The Moon Records (soon)
      </div>
    </div>

    <!-- Legal Links -->
    <div
      class="flex flex-col sm:flex-row justify-center items-center gap-4 mt-8 pt-8 border-t border-outline-variant/10">
      <!-- <a
        href="/press-kit"
        class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300 no-underline">
        Press Kit
      </a> -->
      <a
        href="/impressum"
        class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300 no-underline">
        Impressum
      </a>
      <a
        href="/datenschutz"
        class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40 hover:text-primary transition-colors duration-300 no-underline">
        Datenschutz
      </a>
      <span class="text-[10px] uppercase tracking-[0.05em] text-on-surface/40">
        Made with ❤ by <a href="https://tobeworks.de">Tobeworks Websolutions</a> (v {pack.version})
      </span>
    </div>
  </div>
</footer>
