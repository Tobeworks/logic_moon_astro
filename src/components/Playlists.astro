---
import { Image } from "astro:assets";
import aeterna from "../assets/img/playlists/aeterna_cover2.jpg";
import dark from "../assets/img/playlists/dark cover.jpg";
import home from "../assets/img/playlists/home_cover_01.jpg";
---

<section class="py-32 px-8 md:px-16 bg-surface-container-lowest" id="playlists">
  <div class="container mx-auto">
    <div class="mb-24" data-aos="fade-up">
      <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
        CURATED SOUNDS
      </span>
      <h2 class="text-4xl font-bold tracking-tight">
        SPOTIFY PLAYLISTS
      </h2>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- AETERNA -->
      <div class="group cursor-pointer" data-aos="fade-up">
        <a href="/spotify-playlist/aeterna-ambient-soundscapes" class="block">
          <div class="aspect-square bg-surface-container-lowest overflow-hidden mb-6">
            <Image
              src={aeterna}
              alt="AETERNA - Ambient Soundscapes"
              class="w-full h-full object-cover grayscale-[50%] group-hover:grayscale-0 transition-all duration-700"
              width="500"
              height="500"
            />
          </div>
        </a>
        <h3 class="font-bold text-lg text-on-surface group-hover:text-primary transition-colors">
          <a href="/spotify-playlist/aeterna-ambient-soundscapes" class="no-underline">
            AETERNA
          </a>
        </h3>
        <p class="text-xs opacity-50 uppercase tracking-widest mt-1 text-on-surface">
          AMBIENT SOUNDSCAPES
        </p>
        <p class="text-on-surface-variant font-light leading-relaxed mt-4 text-sm">
          From classic ambient to neoclassical soundscapes and ethereal drone with evolving intensity.
        </p>
      </div>

      <!-- DARK -->
      <div class="group cursor-pointer" data-aos="fade-up" data-aos-delay="100">
        <a href="/spotify-playlist/dark-ambient-drone" class="block">
          <div class="aspect-square bg-surface-container-lowest overflow-hidden mb-6">
            <Image
              src={dark}
              alt="DARK - Dark Ambient"
              class="w-full h-full object-cover grayscale-[50%] group-hover:grayscale-0 transition-all duration-700"
              width="500"
              height="500"
            />
          </div>
        </a>
        <h3 class="font-bold text-lg text-on-surface group-hover:text-primary transition-colors">
          <a href="/spotify-playlist/dark-ambient-drone" class="no-underline">
            DARK
          </a>
        </h3>
        <p class="text-xs opacity-50 uppercase tracking-widest mt-1 text-on-surface">
          DARK AMBIENT DRONE
        </p>
        <p class="text-on-surface-variant font-light leading-relaxed mt-4 text-sm">
          Drone, Melancholia, Blackness, Abyss, Gloom, Escape
        </p>
      </div>

      <!-- HOME -->
      <div class="group cursor-pointer" data-aos="fade-up" data-aos-delay="200">
        <a href="/spotify-playlist/home-ambient-fieldrecordings" class="block">
          <div class="aspect-square bg-surface-container-lowest overflow-hidden mb-6">
            <Image
              src={home}
              alt="HOME"
              class="w-full h-full object-cover grayscale-[50%] group-hover:grayscale-0 transition-all duration-700"
              width="500"
              height="500"
            />
          </div>
        </a>
        <h3 class="font-bold text-lg text-on-surface group-hover:text-primary transition-colors">
          <a href="/spotify-playlist/home-ambient-fieldrecordings" class="no-underline">
            HOME
          </a>
        </h3>
        <p class="text-xs opacity-50 uppercase tracking-widest mt-1 text-on-surface">
          AMBIENT FIELD RECORDINGS
        </p>
        <p class="text-on-surface-variant font-light leading-relaxed mt-4 text-sm">
          Ambient, Lofi, Cassette, Fieldrecording, Texture, Experimental
        </p>
      </div>
    </div>
  </div>
</section>
