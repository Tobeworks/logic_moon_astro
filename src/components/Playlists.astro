---
import { Image } from "astro:assets";
import aeterna from "../assets/img/playlists/aeterna_cover2.jpg";
import dark from "../assets/img/playlists/dark cover.jpg";
import home from "../assets/img/playlists/home_cover_01.jpg";
---

<section class="py-24 bg-primary-600 text-secondary-200" id="playlists">
  <div class="w-[min(1200px,90vw)] mx-auto">
    <div class="mb-8" data-aos="fade-up">
      <div class="font-mono text-xs tracking-[0.25em] uppercase text-accent-500">Playlists</div>
      <h2 class="mt-2 text-[clamp(22px,3.2vw,30px)] leading-tight font-light">I am currently curating mainly three ambient playlists exclusively on Spotify.</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-aos="fade-up">
      <div class="bg-primary-800 border border-primary-700 rounded-[10px] p-5 text-secondary-200">
        <a
          href="/spotify-playlist/aeterna-ambient-soundscapes"
          class="group relative overflow-hidden transition-transform duration-300 hover:scale-105 block">
          <div class="relative">
            <Image
              src={aeterna}
              alt="AETERNA - Ambient Soundscapes"
              class="aspect-square w-full brightness-75 transition-all duration-300 group-hover:brightness-100"
              width="500"
              height="500"
            />
          </div>
        </a>
        <div class="mt-4 font-semibold">AETERNA - Ambient Soundscapes</div>
        <p class="text-secondary-500 leading-relaxed">From classic ambient to neoclassical soundscape and ethereal drone with evolving intensity.</p>
      </div>
      <div class="bg-primary-800 border border-primary-700 rounded-[10px] p-5 text-secondary-200">
        <a
          href="/spotify-playlist/dark-ambient-drone"
          class="group relative overflow-hidden transition-transform duration-300 hover:scale-105 block">
          <div class="relative">
            <Image
              src={dark}
              alt="DARK - Dark Ambient"
              class="aspect-square w-full brightness-75 transition-all duration-300 group-hover:brightness-100"
              width="500"
              height="500"
            />
          </div>
        </a>
        <div class="mt-4 font-semibold">DARK -Dark Ambient</div>
        <p class="text-secondary-500 leading-relaxed">Drone, Melancholia, Blackness, Fog, Abyss, Gloom, Escape</p>
      </div>
      <div class="bg-primary-800 border border-primary-700 rounded-[10px] p-5 text-secondary-200">
        <a
          href="/spotify-playlist/home-ambient-fieldrecordings"
          class="group relative overflow-hidden transition-transform duration-300 hover:scale-105 block">
          <div class="relative">
            <Image
              src={home}
              alt="HOME"
              class="aspect-square w-full brightness-75 transition-all duration-300 group-hover:brightness-100"
              width="500"
              height="500"
            />
          </div>
        </a>
        <div class="mt-4 font-semibold">HOME</div>
        <p class="text-secondary-500 leading-relaxed">Ambient, Lofi, Cassette, Fieldrecording, Texture, Experimental, Ambience, Asian</p>
      </div>
    </div>
  </div>
</section>
