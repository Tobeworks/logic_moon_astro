---
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 3);
---

{
  latestPosts.length > 0 && (
    <section class="section dark" id="news">
      <div class="container">
        <div data-aos="fade-up">
          <div class="section-header">
            <div class="eyebrow">Latest News</div>
            <h2>New releases, updates and features.</h2>
          </div>

          <div class="grid">
            {latestPosts.map((post) => (
              <article class="card">
                {post.data.image && (
                  <div class="card-media">
                    <img
                      src={post.data.image}
                      alt={post.data.title}
                      class="w-full h-full object-cover"
                    />
                  </div>
                )}
                <div class="card-body">
                  <div class="flex justify-between items-start mb-3">
                    <h3 class="card-title text-secondary-200 leading-tight">
                      <a
                        href={`/news/${post.slug}`}
                        class="hover:text-primary-400 transition-colors duration-200">
                        {post.data.title}
                      </a>
                    </h3>
                    <time
                      datetime={post.data.pubDate.toISOString()}
                      class="card-meta whitespace-nowrap ml-4">
                      {post.data.pubDate.toLocaleDateString("en-EN", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                  </div>

                  <p class="text-secondary-500 leading-relaxed mb-6 clamp-3">
                    {post.data.description}
                  </p>

                  <a
                    href={`/news/${post.slug}`}
                    class="card-link text-accent-700 hover:text-accent-600 transition-colors duration-200 inline-block hover:no-underline mono uppercase tracking-[0.25em] text-xs">
                    read the post
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}

<style>
  .main-section {
    min-height: 60vh;
  }
</style>
