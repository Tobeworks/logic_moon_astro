---
interface Props {
  title?: string;
  subtitle?: string;
  label?: string;
}

const {
  title = "The Moon Records",
  subtitle = "An independent label rooted in ambient, electronic and experimental sound. Built for artists who think in textures and atmospheres.",
  label = "Explore The Label",
} = Astro.props;
---

<section class="py-32 px-8 md:px-16 bg-surface" data-aos="fade-up">
  <div class="max-w-4xl mx-auto">

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-12 items-center">

      <div>
        <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
          Label
        </span>
        <h2 class="text-3xl md:text-5xl font-bold tracking-tight uppercase text-on-surface mb-6">
          {title}
        </h2>
        <p class="text-on-surface/60 font-light leading-relaxed max-w-xl">
          {subtitle}
        </p>
      </div>

      <div class="shrink-0">
        <a
          href="https://the-moon-records.de"
          target="_blank"
          rel="noopener noreferrer"
          class="bg-gradient-to-br from-primary to-primary-container text-on-primary px-8 py-4 text-xs font-bold uppercase tracking-widest hover:brightness-110 transition-all no-underline text-center whitespace-nowrap block">
          {label}
        </a>
      </div>

    </div>

    <div class="mt-16 w-full h-px bg-on-surface/10"></div>

    <div class="mt-8 flex flex-col md:flex-row gap-8 md:gap-16">
      <div>
        <p class="text-xs uppercase tracking-widest text-on-surface/40 mb-2">Focus</p>
        <p class="text-sm font-light text-on-surface/70">Ambient · Electronic · Experimental</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-on-surface/40 mb-2">Based in</p>
        <p class="text-sm font-light text-on-surface/70">Germany</p>
      </div>
      <div>
        <p class="text-xs uppercase tracking-widest text-on-surface/40 mb-2">Founded by</p>
        <p class="text-sm font-light text-on-surface/70">Logic Moon</p>
      </div>
    </div>

  </div>
</section>
