---
import releases from "../releases.js";

const latest = releases[0];
const coverPath = latest?.cover ? `/images/covers/${latest.cover}` : null;
const primaryLink = latest?.bandcamp || latest?.spotify || latest?.apple || latest?.amazon || "#";
---

<div class="relative bg-primary-800 border border-primary-700 rounded-2xl p-5 shadow-2xl" id="featured-release">
  <button class="absolute top-2 right-3 w-7 h-7 rounded-full border border-primary-700 bg-primary-900 text-secondary-500 text-lg leading-none grid place-items-center" type="button" aria-label="Close featured release">×</button>
  <div class="text-xs uppercase text-secondary-500 mb-4 font-mono">Featured</div>
  <div class="bg-primary-900 border border-primary-700 rounded-xl overflow-hidden mb-4">
    {coverPath ? (
      <img src={coverPath} alt={latest?.title ?? "Latest release"} class="w-full aspect-square object-cover block" loading="lazy" />
    ) : (
      <div class="w-full aspect-square grid place-items-center text-xs uppercase tracking-[0.2em] text-secondary-500 font-mono">Visual / Artwork</div>
    )}
  </div>
  <div class="text-lg text-secondary-200 font-semibold mb-2">Latest Release</div>
  <div class="text-secondary-500 text-sm mb-4">
    {latest?.title ?? "New release"}
  </div>
  <div class="flex gap-3">
    <a href={primaryLink} class="bg-accent-500 hover:bg-accent-600 text-primary-900 font-semibold px-4 py-2 rounded text-sm hover:no-underline font-mono uppercase">Listen</a>
    <a href="#disco" class="border border-accent-500 text-secondary-300 px-4 py-2 rounded text-sm hover:no-underline font-mono uppercase">Discography</a>
  </div>
</div>

<script>
  const KEY = "lm_featured_release_hidden_until";
  const el = document.getElementById("featured-release");
  const btn = el?.querySelector(".featured-close");

  if (el) {
    const hiddenUntil = Number(localStorage.getItem(KEY) || 0);
    if (Date.now() < hiddenUntil) {
      el.style.display = "none";
    }
  }

  btn?.addEventListener("click", () => {
    const eightDays = 8 * 24 * 60 * 60 * 1000;
    localStorage.setItem(KEY, String(Date.now() + eightDays));
    el.parentElement?.classList.add("is-hiding");
    setTimeout(() => {
      el.style.display = "none";
    }, 350);
  });
</script>
