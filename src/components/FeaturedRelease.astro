---
import releases from "../releases.js";

const latest = releases[0];
const coverPath = latest?.cover ? `/images/covers/${latest.cover}` : null;
const primaryLink = latest?.bandcamp || latest?.spotify || latest?.apple || latest?.amazon || "#";
---

<div class="featured-release" id="featured-release">
  <button class="featured-close" type="button" aria-label="Close featured release">×</button>
  <div class="text-xs uppercase tracking-[0.3em] text-secondary-500 mb-4 mono">Featured</div>
  <div class="featured-card">
    {coverPath ? (
      <img src={coverPath} alt={latest?.title ?? "Latest release"} class="featured-cover" loading="lazy" />
    ) : (
      <div class="featured-cover placeholder">Visual / Artwork</div>
    )}
  </div>
  <div class="text-lg text-secondary-200 font-semibold mb-2">Latest Release</div>
  <div class="text-secondary-500 text-sm mb-4">
    {latest?.title ?? "New release"}
  </div>
  <div class="flex gap-3">
    <a href={primaryLink} class="bg-accent-500 hover:bg-accent-600 text-primary-900 font-semibold px-4 py-2 rounded text-sm hover:no-underline mono">Listen</a>
    <a href="#disco" class="border border-secondary-700 text-secondary-300 px-4 py-2 rounded text-sm hover:no-underline mono">Discography</a>
  </div>
</div>

<script>
  const KEY = "lm_featured_release_hidden_until";
  const el = document.getElementById("featured-release");
  const btn = el?.querySelector(".featured-close");

  if (el) {
    const hiddenUntil = Number(localStorage.getItem(KEY) || 0);
    if (Date.now() < hiddenUntil) {
      el.style.display = "none";
    }
  }

  btn?.addEventListener("click", () => {
    const eightDays = 8 * 24 * 60 * 60 * 1000;
    localStorage.setItem(KEY, String(Date.now() + eightDays));
    el.parentElement?.classList.add("is-hiding");
    setTimeout(() => {
      el.style.display = "none";
    }, 350);
  });
</script>
