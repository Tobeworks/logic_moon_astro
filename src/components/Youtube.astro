---
import { Image } from "astro:assets";
import escape from "../assets/img/youtube_covers/escape_cover.jpg";
import horizon from "../assets/img/youtube_covers/logic moon horizon cover.jpg";
import luminos from "../assets/img/youtube_covers/luminos_cover.jpg";
import metropolis from "../assets/img/youtube_covers/metropolis_cover.jpg";
import arcadia from "../assets/img/youtube_covers/new arcadia cover.jpg";
import quantum from "../assets/img/youtube_covers/the_quantam_sea.jpg";
---

<section class="py-32 px-8 md:px-16 bg-surface-container-lowest" id="youtube">
  <div class="container mx-auto">
    <div class="mb-24" data-aos="fade-up">
      <span class="text-[10px] uppercase tracking-[0.2em] text-primary mb-4 block">
        MOTION DESIGN
      </span>
      <h2 class="text-4xl font-bold tracking-tight">
        YOUTUBE CHANNEL
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-aos="fade-up">
      {[
        { src: quantum, href: "https://www.youtube.com/watch?v=JC6BoKPIQzI", alt: "The Quantum Sea" },
        { src: horizon, href: "https://www.youtube.com/watch?v=0TC4qRclno8", alt: "Horizon" },
        { src: luminos, href: "https://www.youtube.com/watch?v=ik8Yc05pvbY", alt: "Luminos" },
        { src: metropolis, href: "https://www.youtube.com/watch?v=kiVdVITiGKU", alt: "Metropolis" },
        { src: arcadia, href: "https://www.youtube.com/watch?v=U9l-qVb5lQs", alt: "New Arcadia" },
        { src: escape, href: "https://www.youtube.com/watch?v=fnMJi1SRLBQ", alt: "Escape" },
      ].map((video, index) => (
        <a
          href={video.href}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative overflow-hidden bg-surface-container-lowest"
          data-aos="fade-up"
          data-aos-delay={index * 10}
        >
          <div class="relative w-full pt-[56.25%]">
            <Image
              src={video.src}
              alt={video.alt}
              class="absolute top-0 left-0 w-full h-full object-cover grayscale-[50%] opacity-75 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
              format="webp"
              quality={80}
              width={500}
            />
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="w-16 h-16 bg-primary/90 grid place-items-center">
                <svg class="w-8 h-8 text-on-primary" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8 5v14l11-7z"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="flex justify-center mt-16">
      <a
        href="https://www.youtube.com/@LogicMoonMusic"
        target="_blank"
        rel="noopener noreferrer"
        class="uppercase text-[10px] tracking-widest border-b border-on-surface/20 pb-1 hover:border-primary hover:text-primary transition-all no-underline"
      >
        VISIT CHANNEL →
      </a>
    </div>
  </div>
</section>
