---
import { ChevronDownIcon } from "@heroicons/vue/24/solid";
import HeroAnimation from "./HeroAnimation.astro";
---

<section class="min-h-screen w-full relative overflow-hidden">
  <div
    id="anime-demo"
    class="absolute top-6 right-6 w-3 h-3 rounded-full bg-accent-500"
    aria-hidden="true">
  </div>
  <div
    class="absolute inset-0 bg-cover bg-center bg-no-repeat md:bg-fixed hero-bg opacity-25">
  </div>
  <div
    class="absolute inset-0 bg-gradient-to-b from-primary-500/80 via-primary-500/70 to-primary-500">
  </div>

  <div
    class="w-full mx-auto px-4 md:px-8 max-w-6xl min-h-screen relative z-10 grid items-center gap-12 md:grid-cols-[1.1fr,0.9fr] py-24 md:py-28">
    <div>
      <div
        class="text-xs tracking-[0.35em] uppercase text-accent-500 font-semibold mb-4 font-mono"
        data-hero-anim>
        Ambient / Cinematic / Electronic
      </div>
      <h1
        class="cinzel hero logic-moon-title text-secondary-200 text-[clamp(48px,7vw,72px)] leading-[1.05]"
        data-hero-anim>
        <span class="word" data-word="logic">Logic</span>
        <span class="word" data-word="moon">Moon</span>
      </h1>
      <h2
        class="hero mt-4 mb-6 text-secondary-400 text-[clamp(18px,2.4vw,24px)]"
        data-hero-anim>
        Soundscapes
      </h2>
      <div
        class="mt-16 flex items-center gap-6 text-secondary-500 text-xs uppercase tracking-[0.25em] font-mono"
        data-hero-anim>
        <span>Mainz</span>
        <span class="h-px w-12 bg-secondary-700"></span>
        <span>Since 2011</span>
      </div>
    </div>

    <div
      class="absolute bottom-12 left-1/2 -translate-x-1/2"
      data-aos="fade-down"
      data-aos-delay="800">
      <a href="#about" class="scroller" title="scrolldown" aria-label="about">
        <ChevronDownIcon class="w-10 text-accent-500" />
      </a>
    </div>
  </div>
</section>
<HeroAnimation />

<script type="module" is:inline>
  import { animate } from "animejs/animation";
  import { stagger } from "animejs/utils";

  window.__heroAnimLoaded = true;

  function runHeroAnim() {
    const demo = document.getElementById("anime-demo");
    if (demo) {
      animate(demo, {
        translateY: [0, -14],
        direction: "alternate",
        loop: true,
        duration: 800,
        easing: "easeInOutSine",
      });
    }

    const items = document.querySelectorAll("[data-hero-anim]");
    if (!items.length) return;

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    if (prefersReduced) return;

    requestAnimationFrame(() => {
      items.forEach((el) => {
        el.style.opacity = "0";
        el.style.transform = "translateY(12px)";
      });

      requestAnimationFrame(() => {
        animate(items, {
          opacity: [0, 1],
          translateY: [12, 0],
          scale: [0.98, 1],
          duration: 900,
          easing: "easeOutCubic",
          delay: stagger(140, { start: 1500 }),
        });
      });
    });
  }
  runHeroAnim();

</script>
